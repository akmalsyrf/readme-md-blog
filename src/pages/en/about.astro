---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTranslations, getLocaleFromPath } from '../../utils/i18n';
import AboutContent from '../../components/about/AboutContent.astro';

const currentPath = Astro.url.pathname;
const locale = getLocaleFromPath(currentPath);
const t = getTranslations(locale);
---

<BaseLayout title={t.about.title} description={t.about.description}>
  <div class="container mx-auto px-4 py-12">
    <div class="mx-auto max-w-3xl">
      <h1 class="mb-4 text-4xl font-bold">{t.about.title}</h1>
      <AboutContent locale={locale} t={t} />
    </div>
  </div>
</BaseLayout>
